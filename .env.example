# ============================================
# GEMINI API KEYS CONFIGURATION
# ============================================
# Required: At least one Gemini API Key is needed for the application to work.
# You can add multiple keys for load balancing and fallback when one hits quota limits.
# 
# How to get API Keys:
# 1. Go to https://aistudio.google.com/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key" or use existing key
# 4. Copy the key (format: AIzaSy...)
# 
# For multiple keys from different Google accounts:
# - Use GEMINI_API_KEY for your primary key
# - Use GEMINI_API_KEY2, GEMINI_API_KEY3, etc. for additional keys
# - Each key must be from a different Google account to have separate quotas
# - Maximum 5 keys per Google account

# Primary API Key for Heritage Narrator & Key Rotation (Main Key)
GEMINI_API_KEY="AIzaSy_YOUR_PRIMARY_GEMINI_KEY_HERE"

# Backup API Keys for Load Balancing & High-performance TTS Audio Conversion
# (Requires a total of 3 keys: 1 Main + 2 Backup keys from different accounts to rotate and bypass quotas)
GEMINI_API_KEY2="AIzaSy_YOUR_BACKUP_GEMINI_KEY_1_HERE"
GEMINI_API_KEY3="AIzaSy_YOUR_BACKUP_GEMINI_KEY_2_HERE"
# GEMINI_API_KEY4=""
# GEMINI_API_KEY5=""

# ============================================
# GROQ API CONFIGURATION
# ============================================
# Required for dual AI assistance (Superfast Heritage Scriptwriting and Whisper Large STT).
# One key is sufficient to power rapid operations.
# Get a token at: https://console.groq.com/keys
GROQ_API_KEY="gsk_YOUR_GROQ_KEY_HERE"

# ============================================
# REPLICATE API CONFIGURATION
# ============================================
# Required for actual photo and video restoration.
# Get a token at: https://replicate.com/account/personal-access-tokens
REPLICATE_API_TOKEN=""

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# APP_URL: The URL where this applet is hosted.
# - For local development: http://localhost:3000
# - For production: Your deployed URL (e.g., https://your-app.cloud.run)
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================

# Google OAuth Client ID for Google Drive integration
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Node Environment
# - development: Enables hot reload and debugging features
# - production: Optimized for performance
NODE_ENV="development"

# Server Port (Default: 3000)
PORT=3000

# CORS Configuration (if needed)
# CORS_ORIGIN="https://your-frontend-domain.com"

# Logging Level
# - debug: Detailed logs for development
# - info: General information (default)
# - warn: Only warnings and errors
# - error: Only errors
LOG_LEVEL="info"

# Request Timeout (in milliseconds)
# Default: 30000 (30 seconds)
REQUEST_TIMEOUT=30000

# Maximum File Size for Upload (in megabytes)
# Default: 50MB
MAX_FILE_SIZE_MB=50

# ============================================
# NOTES & TROUBLESHOOTING
# ============================================
# 
# 1. Never commit this file with real API keys to version control!
#    Use .env.local for local development and add it to .gitignore
#
# 2. If you see "GEMINI_API_KEY is missing" error:
#    - Make sure you've copied the correct key from AI Studio
#    - Check that the key is not expired
#    - Verify the key has Gemini API access enabled
#
# 3. If you see quota exceeded errors (429):
#    - Add more API keys from different Google accounts
#    - Wait for quota reset (usually every 24 hours)
#    - Consider upgrading to paid tier
#
# 4. Multiple keys load balancing:
#    - The system automatically distributes requests across all keys
#    - If one key fails (quota/error), it switches to the next key
#    - Keys are monitored for performance and error rates
#
# 5. Security best practices:
#    - Use different keys for development and production
#    - Rotate keys periodically
#    - Monitor usage of each key via /api/keys-status endpoint